<Project>

  <!--
    BenchmarkDotNet auto-generates a transient csproj at runtime to host its
    boilerplate. That csproj is not under our control and inherits this file
    via SDK auto-import (its own ImportDirectoryBuildProps=false only stops
    the SDK-level import, not the MSBuild auto-walk). Skip our settings for
    that one project so its <TargetFramework> stays net8.0-only.
  -->
  <PropertyGroup>
    <_OmniIsBenchmarkAutogen Condition="'$(MSBuildProjectName)' == 'BenchmarkDotNet.Autogenerated'">true</_OmniIsBenchmarkAutogen>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true'">
    <TargetFrameworks>net8.0;netstandard2.1</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ImplicitUsings>disable</ImplicitUsings>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(ContinuousIntegrationBuild)' == '' AND ('$(CI)' == 'true' OR '$(GITHUB_ACTIONS)' == 'true')">true</ContinuousIntegrationBuild>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true'">
    <Authors>Codeturion</Authors>
    <Company>Codeturion</Company>
    <Copyright>Copyright (c) Codeturion</Copyright>
    <RepositoryUrl>https://github.com/Codeturion/omni-collections</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/Codeturion/omni-collections</PackageProjectUrl>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>

    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <Version>2.0.0</Version>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true' AND '$(IsPackable)' != 'false'">
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true' AND '$(IsPackable)' != 'false' AND Exists('$(MSBuildThisFileDirectory)LICENSE')">
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>

  <PropertyGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true' AND '$(IsPackable)' != 'false' AND Exists('$(MSBuildThisFileDirectory)README.md')">
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true' AND '$(IsPackable)' != 'false' AND Exists('$(MSBuildThisFileDirectory)README.md')">
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>

  <ItemGroup Condition="'$(_OmniIsBenchmarkAutogen)' != 'true' AND '$(IsPackable)' != 'false'">
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="all" />
    <PackageReference Include="PolySharp" PrivateAssets="all" />
  </ItemGroup>

</Project>
